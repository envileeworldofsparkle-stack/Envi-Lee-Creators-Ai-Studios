# ============================================================
#  .env.local  —  API Keys for Envi Lee POD Studio
#  Copy this file, rename it to .env.local, and fill in your keys.
#  NEVER commit .env.local to git.
# ============================================================

# ── OPTION A: Anthropic / Claude (recommended — matches your current apps)
# Get your key at: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE

# ── OPTION B: OpenAI (GPT-4o)
# Get your key at: https://platform.openai.com → API Keys → Create Key
# Then uncomment Option A in lib/ai.ts and comment out Option B
# OPENAI_API_KEY=sk-proj-YOUR-KEY-HERE

# ── OPTION C: Together AI, Groq, or other OpenAI-compatible provider
# TOGETHER_API_KEY=your-key-here

# ============================================================
#  After adding your key here:
#  1. Save the file as .env.local (remove the .example extension)
#  2. Run: npm run dev — AI will work immediately on localhost
#  3. For Vercel production:
#     Go to vercel.com → Your Project → Settings → Environment Variables
#     Add the same key(s) there → Redeploy
# ============================================================
